[global]
    monitor = 0
    follow = mouse
    width = 300
    height = 100
    offset = 10x40
    font = monospace 11
    timeout = 4

[urgency_low]
    background = "#1a1a1a"
    foreground = "#aaaaaa"
    timeout = 3

[urgency_normal]
    background = "#1a1a1a"
    foreground = "#cccccc"
    timeout = 4

[urgency_critical]
    background = "#ff4444"
    foreground = "#ffffff"
    timeout = 0
