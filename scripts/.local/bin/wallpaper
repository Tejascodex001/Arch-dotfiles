#!/bin/bash
WALLPAPER_DIR="$HOME/Pictures/wallpapers"
THUMB_DIR="$HOME/.cache/wallpaper-thumbs"

# Generate missing thumbnails
for img in "$WALLPAPER_DIR"/*; do
    filename=$(basename "$img")
    thumb="$THUMB_DIR/$filename"
    if [ ! -f "$thumb" ]; then
        convert "$img" -thumbnail 500x500^ -gravity center -extent 500x500 "$thumb" 2>/dev/null
    fi
done

# Build rofi entries with icons
ENTRIES=""
for img in "$WALLPAPER_DIR"/*; do
    filename=$(basename "$img")
    thumb="$THUMB_DIR/$filename"
    ENTRIES+="$filename\x00icon\x1f$thumb\n"
done

# Show rofi picker
CHOICE=$(echo -e "$ENTRIES" | rofi \
    -dmenu \
    -p "Wallpaper" \
    -show-icons \
    -icon-size 150 \
    -theme ~/.config/rofi/wallpaper.rasi)


[ -z "$CHOICE" ] && exit 0

FULL_PATH="$WALLPAPER_DIR/$CHOICE"

# Apply wallpaper
pkill swaybg
swaybg -i "$FULL_PATH" -m fill &

# Save for persistence
echo "$FULL_PATH" > ~/.cache/last_wallpaper

notify-send "Wallpaper" "Set to $CHOICE"
