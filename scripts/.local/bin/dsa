#!/bin/bash
# Opens a ready-to-use DSA tmux session

SESSION="dsa"
PROBLEMS_DIR="$HOME/dsa/problems"

# Don't create duplicate session
tmux has-session -t $SESSION 2>/dev/null
if [ $? == 0 ]; then
    tmux attach -t $SESSION
    exit 0
fi

# Create session
tmux new-session -d -s $SESSION -c $PROBLEMS_DIR

# Left pane: Neovim (70% width)
tmux send-keys -t $SESSION "v ." Enter

# Right pane: terminal for compile/run (30% width)
tmux split-window -h -p 30 -t $SESSION
tmux send-keys -t $SESSION "cd $PROBLEMS_DIR" Enter

# Focus left pane (editor)
tmux select-pane -t $SESSION:1.1

tmux attach -t $SESSION
