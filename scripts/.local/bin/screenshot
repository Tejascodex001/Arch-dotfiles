#!/bin/bash
# screenshot [full|area|window]

case "$1" in
    area)   grim -g "$(slurp)" ~/Pictures/$(date +%Y%m%d_%H%M%S).png ;;
    window) grim -g "$(hyprctl activewindow -j | jq -r '"\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"')" ~/Pictures/$(date +%Y%m%d_%H%M%S).png ;;
    *)      grim ~/Pictures/$(date +%Y%m%d_%H%M%S).png ;;
esac

notify-send "Screenshot" "Saved to ~/Pictures"
