#!/bin/bash
SAVEDIR="$HOME/Pictures/screenshots"
mkdir -p "$SAVEDIR"
FILENAME="$SAVEDIR/$(date +%Y%m%d_%H%M%S).png"

case "$1" in
    area)   grim -g "$(slurp)" "$FILENAME" ;;
    window) grim -g "$(hyprctl activewindow -j | jq -r '"\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"')" "$FILENAME" ;;
    *)      grim "$FILENAME" ;;
esac

notify-send "Screenshot" "Saved to ~/Pictures/screenshots"
