#!/bin/bash

OPTIONS="箚뙻 Lock\n箚쨪 Sleep\n箚쐣 Reboot\n箚뛽 Logout\n箚맓 Shutdown"

CHOICE=$(echo -e "$OPTIONS" | fuzzel --dmenu --prompt "Power: " --lines 5 --width 20)

case "$CHOICE" in
    *Lock*)     hyprlock ;;
    *Sleep*)    systemctl suspend ;;
    *Reboot*)   systemctl reboot ;;
    *Logout*)   hyprctl dispatch exit ;;
    *Shutdown*) systemctl poweroff ;;
esac
