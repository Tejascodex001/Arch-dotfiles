{
  "layer": "top",
  "position": "top",
  "height": 28,
  "spacing": 6,

  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": ["network", "pulseaudio", "backlight", "cpu", "battery", "custom/gpu", "bluetooth", "custom/wallpaper", "custom/accent", "custom/power"],

  "hyprland/workspaces": {
    "format": "{id}",
    "sort-by-number": true
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 40
  },

  "clock": {
    "format": "{:%H:%M  %a %d}",
    "interval": 60,
    "tooltip": false
  },

  "network": {
    "interval": 5,
    "format-wifi": "󰖩 {signalStrength}%",
    "format-ethernet": "󰈀",
    "format-disconnected": "󰖪",
    "on-click": "nm-connection-editor",
    "tooltip": false
  },

  "pulseaudio": {
    "format": "󰕾 {volume}%",
    "format-muted": "󰖁",
    "scroll-step": 5,
    "on-click": "pavucontrol"
  },

  "cpu": {
    "interval": 5,
    "format": "󰻠 {usage}%"
  },

  "battery": {
    "interval": 10,
    "format": "󰁹 {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "states": {
      "warning": 30,
      "critical": 15
    }
  },

  "bluetooth": {
    "format": "󰂯",
    "format-disabled": "󰂲",
    "interval": 15,
    "on-click": "blueman-manager",
    "tooltip": false
  },

  "custom/accent": {
    "format": "󰏘",
    "on-click": "~/.local/bin/accent",
    "exec": "echo",
    "interval": 86400
  },

  "custom/power": {
    "format": "󰐥",
    "on-click": "/home/produser/.local/bin/powermenu",
    "tooltip": false
},
  
  "custom/gpu": {
    "format": "󰢮",
    "on-click": "/home/produser/.local/bin/gpu-mode",
    "exec": "/home/produser/.local/bin/gpu-status",
    "interval": 30,
    "tooltip": true
  },

"backlight": {
    "device": "intel_backlight",
    "format": "󰃞  {percent}%",
    "scroll-step": 5,
    "on-scroll-up": "brightnessctl -d intel_backlight set 5%+",
    "on-scroll-down": "brightnessctl -d intel_backlight set 5%-"
  }
}
